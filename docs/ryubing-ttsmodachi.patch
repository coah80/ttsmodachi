+        private static void DumpContextObjects(ExecutionContext context, IMemoryManager memory, ulong address)
+        {
+            if (string.IsNullOrWhiteSpace(ContextDumpDir) || ContextDumpBytes <= 0 || ContextDumpRegisters.Length == 0)
+            {
+                return;
+            }
+
+            int dumpIndex;
+            lock (Lock)
+            {
+                dumpIndex = _contextDumpCount++;
+            }
+
+            try
+            {
+                Directory.CreateDirectory(ContextDumpDir);
+                string prefix = string.Create(
+                    CultureInfo.InvariantCulture,
+                    $"context-{dumpIndex:000000}-pc-{address:x}");
+                File.WriteAllText(Path.Combine(ContextDumpDir, prefix + ".txt"), FormatRequestRegisters(context));
+
+                foreach (int register in ContextDumpRegisters)
+                {
+                    if ((uint)register > 31)
+                    {
+                        continue;
+                    }
+
+                    ulong pointer = context.GetX(register);
+                    if (pointer < 0x10000)
+                    {
+                        continue;
+                    }
+
+                    byte[] data = new byte[ContextDumpBytes];
+                    try
+                    {
+                        for (int index = 0; index < data.Length; index++)
+                        {
+                            data[index] = memory.Read<byte>(pointer + (ulong)index);
+                        }
+                    }
+                    catch
+                    {
+                        continue;
+                    }
+
+                    string fileName = string.Create(
+                        CultureInfo.InvariantCulture,
+                        $"{prefix}-x{register:00}-{pointer:x}.bin");
+                    File.WriteAllBytes(Path.Combine(ContextDumpDir, fileName), data);
+                }
+            }
+            catch
+            {
+            }
+        }
