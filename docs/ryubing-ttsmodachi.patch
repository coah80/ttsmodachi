diff --git a/src/Ryujinx.Input/HLE/TtsmodachiHeadlessInput.cs b/src/Ryujinx.Input/HLE/TtsmodachiHeadlessInput.cs
new file mode 100644
index 0000000..73328e6
--- /dev/null
+++ b/src/Ryujinx.Input/HLE/TtsmodachiHeadlessInput.cs
@@ -0,0 +1,284 @@
+using Ryujinx.HLE.HOS.Services.Hid;
+using System;
+using System.Collections.Generic;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+
+namespace Ryujinx.Input.HLE
+{
+    internal static class TtsmodachiHeadlessInput
+    {
+        private static readonly InputEvent[] Script = ParseScript(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_INPUT_SCRIPT"));
+        private static readonly bool AutoA = bool.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_AUTO_A"), out bool autoA) && autoA;
+        private static readonly ulong AutoAStartFrame = ReadUlong("RYUJINX_TTSMODACHI_AUTO_A_START_FRAME", 120);
+        private static readonly ulong AutoAIntervalFrames = ReadUlong("RYUJINX_TTSMODACHI_AUTO_A_INTERVAL_FRAMES", 90);
+        private static readonly ulong AutoADurationFrames = ReadUlong("RYUJINX_TTSMODACHI_AUTO_A_DURATION_FRAMES", 4);
+        private static readonly string LiveScriptPath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_INPUT_FILE");
+        private static readonly string TracePath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_INPUT_TRACE");
+        private static readonly object TraceLock = new();
+        private const int StickMax = 32767;
+        private const int LiveScriptCheckFrames = 30;
+        private static ulong _lastLiveScriptCheckFrame;
+        private static long _liveScriptLastWriteTicks;
+        private static InputEvent[] _liveScript = [];
+
+        public static void Apply(ulong frame, List<GamepadInput> states)
+        {
+            ControllerKeys buttons = (ControllerKeys)0;
+            JoystickPosition lStick = default;
+            JoystickPosition rStick = default;
+
+            foreach (InputEvent inputEvent in GetEvents(frame))
+            {
+                if (frame >= inputEvent.StartFrame && frame < inputEvent.StartFrame + inputEvent.DurationFrames)
+                {
+                    buttons |= inputEvent.Buttons;
+                    lStick = MergeStick(lStick, inputEvent.LStick);
+                    rStick = MergeStick(rStick, inputEvent.RStick);
+                }
+            }
+
+            if (AutoA && frame >= AutoAStartFrame && AutoAIntervalFrames > 0 && (frame - AutoAStartFrame) % AutoAIntervalFrames < AutoADurationFrames)
+            {
+                buttons |= ControllerKeys.A;
+            }
+
+            if (buttons == (ControllerKeys)0 && IsZero(lStick) && IsZero(rStick))
+            {
+                return;
+            }
+
+            Trace(frame, buttons, lStick, rStick);
+
+            int playerIndex = states.FindIndex(input => input.PlayerId == PlayerIndex.Player1);
+            if (playerIndex < 0)
+            {
+                playerIndex = states.FindIndex(input => input.PlayerId == PlayerIndex.Handheld);
+            }
+
+            if (playerIndex < 0)
+            {
+                states.Add(new GamepadInput
+                {
+                    PlayerId = PlayerIndex.Player1,
+                    Buttons = buttons,
+                    LStick = lStick,
+                    RStick = rStick,
+                });
+                return;
+            }
+
+            GamepadInput state = states[playerIndex];
+            state.Buttons |= buttons;
+            state.LStick = MergeStick(state.LStick, lStick);
+            state.RStick = MergeStick(state.RStick, rStick);
+            states[playerIndex] = state;
+        }
+
+        private static IEnumerable<InputEvent> GetEvents(ulong frame)
+        {
+            foreach (InputEvent inputEvent in Script)
+            {
+                yield return inputEvent;
+            }
+
+            foreach (InputEvent inputEvent in GetLiveScript(frame))
+            {
+                yield return inputEvent;
+            }
+        }
+
+        private static InputEvent[] GetLiveScript(ulong frame)
+        {
+            if (string.IsNullOrWhiteSpace(LiveScriptPath) || frame - _lastLiveScriptCheckFrame < LiveScriptCheckFrames)
+            {
+                return _liveScript;
+            }
+
+            _lastLiveScriptCheckFrame = frame;
+
+            try
+            {
+                FileInfo fileInfo = new(LiveScriptPath);
+                if (!fileInfo.Exists)
+                {
+                    _liveScript = [];
+                    _liveScriptLastWriteTicks = 0;
+                    return _liveScript;
+                }
+
+                long ticks = fileInfo.LastWriteTimeUtc.Ticks;
+                if (ticks == _liveScriptLastWriteTicks)
+                {
+                    return _liveScript;
+                }
+
+                _liveScript = ParseScript(File.ReadAllText(LiveScriptPath));
+                _liveScriptLastWriteTicks = ticks;
+            }
+            catch
+            {
+                _liveScript = [];
+            }
+
+            return _liveScript;
+        }
+
+        private static InputEvent[] ParseScript(string script)
+        {
+            if (string.IsNullOrWhiteSpace(script))
+            {
+                return [];
+            }
+
+            return script
+                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(ParseEvent)
+                .Where(inputEvent => (inputEvent.Buttons != (ControllerKeys)0 || !IsZero(inputEvent.LStick) || !IsZero(inputEvent.RStick)) && inputEvent.DurationFrames > 0)
+                .ToArray();
+        }
+
+        private static InputEvent ParseEvent(string value)
+        {
+            string[] parts = value.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
+            if (parts.Length < 2 || !ulong.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong startFrame))
+            {
+                return default;
+            }
+
+            ulong durationFrames = 4;
+            if (parts.Length >= 3)
+            {
+                ulong.TryParse(parts[2], NumberStyles.Integer, CultureInfo.InvariantCulture, out durationFrames);
+            }
+
+            ParsedControls controls = ParseControls(parts[1]);
+            if (parts.Length >= 7)
+            {
+                controls = controls with
+                {
+                    LStick = new JoystickPosition
+                    {
+                        Dx = ParseStickValue(parts[3]),
+                        Dy = ParseStickValue(parts[4]),
+                    },
+                    RStick = new JoystickPosition
+                    {
+                        Dx = ParseStickValue(parts[5]),
+                        Dy = ParseStickValue(parts[6]),
+                    },
+                };
+            }
+
+            return new InputEvent(startFrame, Math.Max(durationFrames, 1), controls.Buttons, controls.LStick, controls.RStick);
+        }
+
+        private static ParsedControls ParseControls(string value)
+        {
+            ControllerKeys buttons = (ControllerKeys)0;
+            JoystickPosition lStick = default;
+            JoystickPosition rStick = default;
+
+            foreach (string part in value.Split(['+', '|', ','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
+            {
+                string normalized = part.Replace("_", "", StringComparison.Ordinal).Replace("-", "", StringComparison.Ordinal).ToLowerInvariant();
+                switch (normalized)
+                {
+                    case "lleft":
+                    case "leftstickleft":
+                        lStick.Dx = -StickMax;
+                        continue;
+                    case "lright":
+                    case "leftstickright":
+                        lStick.Dx = StickMax;
+                        continue;
+                    case "lup":
+                    case "leftstickup":
+                        lStick.Dy = StickMax;
+                        continue;
+                    case "ldown":
+                    case "leftstickdown":
+                        lStick.Dy = -StickMax;
+                        continue;
+                    case "rleft":
+                    case "rightstickleft":
+                        rStick.Dx = -StickMax;
+                        continue;
+                    case "rright":
+                    case "rightstickright":
+                        rStick.Dx = StickMax;
+                        continue;
+                    case "rup":
+                    case "rightstickup":
+                        rStick.Dy = StickMax;
+                        continue;
+                    case "rdown":
+                    case "rightstickdown":
+                        rStick.Dy = -StickMax;
+                        continue;
+                }
+
+                if (Enum.TryParse(part, true, out ControllerKeys parsed))
+                {
+                    buttons |= parsed;
+                }
+            }
+
+            return new ParsedControls(buttons, lStick, rStick);
+        }
+
+        private static int ParseStickValue(string value)
+        {
+            if (!float.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out float parsed))
+            {
+                return 0;
+            }
+
+            if (Math.Abs(parsed) <= 1.0f)
+            {
+                parsed *= StickMax;
+            }
+
+            return Math.Clamp((int)MathF.Round(parsed), -StickMax, StickMax);
+        }
+
+        private static JoystickPosition MergeStick(JoystickPosition current, JoystickPosition next)
+        {
+            return new JoystickPosition
+            {
+                Dx = next.Dx != 0 ? next.Dx : current.Dx,
+                Dy = next.Dy != 0 ? next.Dy : current.Dy,
+            };
+        }
+
+        private static bool IsZero(JoystickPosition position)
+        {
+            return position.Dx == 0 && position.Dy == 0;
+        }
+
+        private static ulong ReadUlong(string name, ulong fallback)
+        {
+            return ulong.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong value)
+                ? value
+                : fallback;
+        }
+
+        private static void Trace(ulong frame, ControllerKeys buttons, JoystickPosition lStick, JoystickPosition rStick)
+        {
+            if (string.IsNullOrWhiteSpace(TracePath))
+            {
+                return;
+            }
+
+            lock (TraceLock)
+            {
+                Directory.CreateDirectory(Path.GetDirectoryName(Path.GetFullPath(TracePath)) ?? ".");
+                File.AppendAllText(TracePath, FormattableString.Invariant($"{DateTimeOffset.UtcNow:O},{frame},{buttons},{lStick.Dx},{lStick.Dy},{rStick.Dx},{rStick.Dy}") + Environment.NewLine);
+            }
+        }
+
+        private readonly record struct ParsedControls(ControllerKeys Buttons, JoystickPosition LStick, JoystickPosition RStick);
+        private readonly record struct InputEvent(ulong StartFrame, ulong DurationFrames, ControllerKeys Buttons, JoystickPosition LStick, JoystickPosition RStick);
+    }
+}
