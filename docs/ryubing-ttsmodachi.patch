+using System;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+using System.Text;
+
+namespace ARMeilleure.Translation
+{
+    public static class TtsmodachiTextInject
+    {
+        private const int DefaultMaxBytes = 96;
+
+        private static readonly ulong BaseAddress = ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_GUEST_TRACE_BASE"));
+        private static readonly ulong[] TargetAddresses = ParseTargets(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_ADDRS") ?? Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_ADDR"));
+        private static readonly byte[] RawTextBytes = Encoding.UTF8.GetBytes(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT") ?? string.Empty);
+        private static readonly string TextFile = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_FILE");
+        private static readonly int MaxBytes = int.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_MAX_BYTES"), NumberStyles.Integer, CultureInfo.InvariantCulture, out int maxBytes)
+            ? Math.Clamp(maxBytes, 1, 512)
+            : DefaultMaxBytes;
+        private static readonly ulong PointerAddress = ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_POINTER"));
+        private static readonly int PointerLength = int.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TEXT_INJECT_LENGTH"), NumberStyles.Integer, CultureInfo.InvariantCulture, out int pointerLength)
+            ? Math.Clamp(pointerLength, 0, 512)
+            : 0;
+        private static readonly object Lock = new();
+
+        private static long _lastTextFileTicks;
+        private static byte[] _lastTextFileBytes = [];
+
+        public static bool Enabled => TargetAddresses.Length > 0 && (TextBytes.Length > 0 || !string.IsNullOrWhiteSpace(TextFile) || (PointerAddress != 0 && PointerLength > 0));
+        public static bool UsesPointer => PointerAddress != 0 && PointerLength > 0;
+        public static ulong Pointer => PointerAddress;
+        public static int Length => UsesPointer ? PointerLength : TextBytes.Length;
+        public static byte[] TextBytes => ReadTextBytes();
+
+        public static bool Matches(ulong address)
+        {
+            foreach (ulong targetAddress in TargetAddresses)
+            {
+                if (address == targetAddress)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && address >= BaseAddress && address - BaseAddress == targetAddress)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && targetAddress < BaseAddress && address == BaseAddress + targetAddress)
+                {
+                    return true;
+                }
+            }
+
+            return false;
+        }
+
+        private static ulong[] ParseTargets(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return [];
+            }
+
+            return value
+                .Split([',', ';', ' ', '\n', '\r', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(ParseAddress)
+                .Where(address => address != 0)
+                .Distinct()
+                .ToArray();
+        }
+
+        private static ulong ParseAddress(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return 0;
+            }
+
+            value = value.Trim();
+            if (value.StartsWith("0x", StringComparison.OrdinalIgnoreCase))
+            {
+                return ulong.TryParse(value[2..], NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong parsed) ? parsed : 0;
+            }
+
+            return ulong.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong decimalParsed)
+                ? decimalParsed
+                : ulong.TryParse(value, NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong hexParsed)
+                    ? hexParsed
+                    : 0;
+        }
+
+        private static byte[] ReadTextBytes()
+        {
+            if (string.IsNullOrWhiteSpace(TextFile))
+            {
+                return RawTextBytes.Take(MaxBytes).ToArray();
+            }
+
+            lock (Lock)
+            {
+                try
+                {
+                    FileInfo fileInfo = new(TextFile);
+                    if (!fileInfo.Exists)
+                    {
+                        _lastTextFileTicks = 0;
+                        _lastTextFileBytes = [];
+                        return _lastTextFileBytes;
+                    }
+
+                    long ticks = fileInfo.LastWriteTimeUtc.Ticks;
+                    if (ticks == _lastTextFileTicks)
+                    {
+                        return _lastTextFileBytes;
+                    }
+
+                    string text = File.ReadAllText(TextFile).Replace('\n', ' ').Trim();
+                    _lastTextFileBytes = Encoding.UTF8.GetBytes(text).Take(MaxBytes).ToArray();
+                    _lastTextFileTicks = ticks;
+                }
+                catch
+                {
+                    _lastTextFileBytes = [];
+                }
+
+                return _lastTextFileBytes;
+            }
+        }
+    }
+}
