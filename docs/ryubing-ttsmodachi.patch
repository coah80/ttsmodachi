+                Trace(memory, address, "capture", "capture-address", 0, 0);
+            }
+
+            if (Matches(address, PcmDumpAddresses))
+            {
+                DumpPcm(context, memory);
+            }
+
+            if (Matches(address, ConsumerCaptureAddresses))
+            {
+                Trace(memory, address, "consumer", CaptureConsumerCall(context, memory, address), 0, 0);
+            }
+
+            if (Matches(address, ContextTraceAddresses))
+            {
+                TraceContext(context, memory, address);
+            }
+
+            bool isPollAddress = Matches(address, PollAddresses);
+            bool isCaptureDispatchAddress = DispatchOnCapture && Matches(address, CaptureAddresses);
+            bool canParkHere = ParkEnabled && (isPollAddress || (ParkOnCaptureReady && isCaptureDispatchAddress));
+
+            if (!isPollAddress && !isCaptureDispatchAddress)
+            {
+                return 0;
+            }
+
+            DateTime parkStartedAt = DateTime.UtcNow;
+            bool tracedPark = false;
+            bool parked = false;
+
+            try
+            {
+                while (true)
+                {
+                    lock (Lock)
+                    {
+                        RequestProbe probe = ProbeRequestObject(memory);
+                        ulong ttsObject = probe.Ready ? probe.RequestObject : 0;
+                        bool restoreContext = ContextRestoreDispatch && isCaptureDispatchAddress && TrampolineReturnAddress != 0;
+                        if (isCaptureDispatchAddress && !restoreContext && ttsObject != 0 && probe.CapturedObject != probe.RequestObject)
+                        {
+                            if (TracePolls)
+                            {
+                                Trace(memory, address, "poll", "capture-object-mismatch", ttsObject, 0, probe);
+                            }
+                            return 0;
+                        }
+
+                        if (ttsObject == 0)
+                        {
+                            if (TracePolls)
+                            {
+                                Trace(memory, address, "poll", probe.Reason, 0, 0, probe);
+                            }
+                            return 0;
+                        }
+
+                        ApplyPcmAck(memory, address, ttsObject, probe);
+                        DumpRequestState(memory, address, probe, "ready");
+
+                        ulong dispatchObject = DispatchWrapper ? _wrapperObject : ttsObject;
+                        if (dispatchObject == 0)
+                        {
+                            if (TracePolls)
+                            {
+                                Trace(memory, address, "poll", "no-dispatch-object", ttsObject, 0, probe);
+                            }
+                            return 0;
+                        }
+
+                        if (_dispatchCount >= DispatchMax)
+                        {
+                            Trace(memory, address, "poll", "dispatch-max", ttsObject, 0, probe);
+                            return 0;
+                        }
+
+                        if (CanDispatchNow())
+                        {
+                            byte[] text = ReadPendingText();
+                            if (text.Length != 0)
+                            {
+                                PrepareObject(memory, ttsObject, text);
+                                if (restoreContext)
+                                {
+                                    SaveContext(context, ContextResumeAddress != 0 ? ContextResumeAddress : address + 4);
+                                    context.SetX(30, TrampolineReturnAddress);
+                                }
+                                else if (DispatchContextReplay && TryRestoreDispatchContext(context, memory, address, probe))
+                                {
+                                    context.SetX(30, isPollAddress && ReturnAddress != 0 ? ReturnAddress : address + 4);
+                                }
+                                else if (RequestContextReplay && TryRestoreRequestContext(context, memory, address, probe))
+                                {
+                                    context.SetX(30, isPollAddress && ReturnAddress != 0 ? ReturnAddress : address + 4);
+                                }
+                                else
+                                {
+                                    CaptureDispatchContext(context, address);
+                                    context.SetX(30, isPollAddress && ReturnAddress != 0 ? ReturnAddress : address + 4);
+                                }
+                                context.SetX(0, dispatchObject);
+                                _dispatchCount++;
+                                _consumerKickCount = 0;
+                                _consumerKickAfterDispatchCount = 0;
+                                _lastConsumerKickAt = default;
+                                _lastDispatchAt = DateTime.UtcNow;
+                                _pcmDumpRemainingBytes = EstimatePcmBytes(text.Length);
+                                MarkTextDispatched();
+                                DumpRequestState(memory, address, probe, "dispatch");
+                                if (TraceRequestRegisters)
+                                {
+                                    Trace(memory, address, "request-registers", FormatRequestRegisters(context), ttsObject, text.Length, probe);
+                                }
+                                Trace(memory, address, "dispatch", "ok", ttsObject, text.Length, probe);
+                                ApplyMemoryPatches(memory, address, "dispatch", ttsObject, probe);
+
+                                return RequestAddress;
+                            }
+
+                            if (_pcmDumpRemainingBytes > 0)
+                            {
+                                if (TryKickConsumer(context, memory, address, ttsObject, probe, address, "kick", out ulong consumerAddress))
+                                {
+                                    return consumerAddress;
+                                }
+
+                                if (TracePolls)
+                                {
+                                    Trace(memory, address, "poll", "pcm-pending", ttsObject, 0, probe);
+                                }
+                                return 0;
+                            }
+
+                            if (!canParkHere)
+                            {
+                                if (TracePolls)
+                                {
+                                    Trace(memory, address, "poll", "no-text", ttsObject, 0, probe);
+                                }
+                                return 0;
+                            }
+
+                            if (!tracedPark)
+                            {
+                                Trace(memory, address, "park", "waiting-for-text", ttsObject, 0, probe);
+                                tracedPark = true;
+                            }
+
+                            EnterPark(ref parked);
+                        }
+                        else if (!canParkHere)
+                        {
+                            if (TracePolls)
+                            {
+                                Trace(memory, address, "poll", "dispatch-interval", ttsObject, 0, probe);
+                            }
+                            return 0;
+                        }
+                        else if (_pcmDumpRemainingBytes > 0)
+                        {
+                            if (TryKickConsumer(context, memory, address, ttsObject, probe, address, "kick", out ulong consumerAddress))
+                            {
+                                return consumerAddress;
+                            }
+
+                            if (TracePolls)
+                            {
+                                Trace(memory, address, "poll", "pcm-pending", ttsObject, 0, probe);
+                            }
+                            return 0;
+                        }
+                    }
+
+                    if (ParkMaxMs > 0 && (DateTime.UtcNow - parkStartedAt).TotalMilliseconds >= ParkMaxMs)
+                    {
+                        return 0;
+                    }
+
+                    Thread.Sleep(ParkPollMs);
+                }
+            }
+            finally
+            {
+                ExitPark(ref parked);
+            }
+        }
+
+        private static void EnterPark(ref bool parked)
+        {
+            if (parked)
+            {
+                return;
+            }
+
+            System.Threading.Interlocked.Increment(ref _parkDepth);
+            parked = true;
+        }
+
+        private static void ExitPark(ref bool parked)
+        {
+            if (!parked)
+            {
+                return;
+            }
+
+            System.Threading.Interlocked.Decrement(ref _parkDepth);
+            parked = false;
+        }
+
+        private static bool CanDispatchNow()
+        {
+            return _dispatchCount == 0 || DispatchIntervalMs == 0 || (DateTime.UtcNow - _lastDispatchAt).TotalMilliseconds >= DispatchIntervalMs;
+        }
