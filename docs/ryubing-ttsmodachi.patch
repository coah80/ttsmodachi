+                writer.Write(ToHex(state.ManagerBase));
+                writer.Write(',');
+                writer.Write(ToHex(state.GlobalObject));
+                writer.Write(',');
+                writer.Write(ToHex(state.CapturedObject));
+                writer.Write(',');
+                writer.Write(ToHex(state.CapturedWrapper));
+                writer.Write(',');
+                writer.Write(ToHex(requestObject != 0 ? requestObject : state.RequestObject));
+                writer.Write(',');
+                writer.Write(ToHex(state.VoiceContext));
+                writer.Write(',');
+                writer.Write(state.ReadyFlag.ToString(CultureInfo.InvariantCulture));
+                writer.Write(',');
+                writer.Write(state.TextLength.ToString(CultureInfo.InvariantCulture));
+                writer.Write(',');
+                writer.Write(textHash);
+                writer.Write(',');
+                writer.WriteLine(textPreview);
+                _traceEvents++;
+            }
+            catch
+            {
+            }
+        }
+
+        private static (string Hash, string Preview) ReadTraceText(IMemoryManager memory, ulong requestObject, int currentTextLength)
+        {
+            if (requestObject == 0 || currentTextLength <= 0)
+            {
+                return ("", "");
+            }
+
+            int length = Math.Clamp(currentTextLength, 0, MaxBytes + 1);
+            byte[] bytes = new byte[length];
+            try
+            {
+                ulong textPointer = memory.Read<ulong>(requestObject + TextPointerOffset);
+                if (textPointer == 0)
+                {
+                    textPointer = requestObject + TextBufferOffset;
+                }
+
+                for (int index = 0; index < length; index++)
+                {
+                    byte value = memory.Read<byte>(textPointer + (ulong)index);
+                    if (value == 0)
+                    {
+                        length = index;
+                        break;
+                    }
+                    bytes[index] = value;
+                }
+            }
+            catch
+            {
+                return ("", "");
+            }
+
+            if (length == 0)
+            {
+                return ("", "");
+            }
+
+            byte[] textBytes = bytes.Take(length).ToArray();
+            string hash = Convert.ToHexString(SHA256.HashData(textBytes)).ToLowerInvariant()[..16];
+            string preview = Encoding.UTF8.GetString(textBytes)
+                .Replace(',', ' ')
+                .Replace('\n', ' ')
+                .Replace('\r', ' ')
+                .Trim();
+            return (hash, preview);
+        }
+
+        private static void TracePcm(ExecutionContext context, IMemoryManager memory, ulong pointer, ulong requestedSize, int writtenSize)
+        {
+            if (string.IsNullOrWhiteSpace(TracePath) || TraceMaxEvents == 0 || _traceEvents >= TraceMaxEvents)
+            {
+                return;
+            }
+
+            try
+            {
+                ulong frame0 = context.GetX(29);
+                ulong frame0Return = ReadFrameReturnAddress(memory, frame0);
+                ulong frame1 = frame0 == 0 ? 0 : ReadPointer(memory, frame0);
+                ulong frame1Return = ReadFrameReturnAddress(memory, frame1);
+                ulong frame2 = frame1 == 0 ? 0 : ReadPointer(memory, frame1);
+                ulong frame2Return = ReadFrameReturnAddress(memory, frame2);
+                using StreamWriter writer = File.AppendText(TracePath);
+                writer.Write(DateTime.UtcNow.ToString("O", CultureInfo.InvariantCulture));
+                writer.Write(',');
+                writer.Write(ToHex(PcmDumpAddresses.Length == 0 ? 0 : PcmDumpAddresses[0]));
+                writer.Write(",pcm,dump,");
+                writer.Write(_dispatchCount.ToString(CultureInfo.InvariantCulture));
+                writer.Write(",0,");
+                writer.Write(ToHex(RequestAddress));
+                writer.Write(',');
+                writer.Write(ToHex(ReturnAddress));
+                writer.Write(',');
+                writer.Write(DispatchWrapper ? "1" : "0");
+                writer.Write(",,,,,,,,,,");
+                writer.Write(" pcm_pointer=");
+                writer.Write(ToHex(pointer));
+                writer.Write(" requested=");
+                writer.Write(requestedSize.ToString(CultureInfo.InvariantCulture));
+                writer.Write(" written=");
+                writer.Write(writtenSize.ToString(CultureInfo.InvariantCulture));
+                writer.Write(" total=");
+                writer.Write(_pcmDumpBytes.ToString(CultureInfo.InvariantCulture));
+                writer.Write(" remaining=");
+                writer.Write(_pcmDumpRemainingBytes.ToString(CultureInfo.InvariantCulture));
+                writer.Write(" x29=");
+                writer.Write(ToHex(frame0));
+                writer.Write(" lr0=");
+                writer.Write(ToHex(frame0Return));
+                writer.Write(" fp1=");
+                writer.Write(ToHex(frame1));
+                writer.Write(" lr1=");
+                writer.Write(ToHex(frame1Return));
+                writer.Write(" fp2=");
+                writer.Write(ToHex(frame2));
+                writer.Write(" lr2=");
+                writer.WriteLine(ToHex(frame2Return));
+                _traceEvents++;
+            }
+            catch
+            {
+            }
+        }
+
+        private static ulong ReadFrameReturnAddress(IMemoryManager memory, ulong framePointer)
+        {
+            return framePointer == 0 ? 0 : ReadPointer(memory, framePointer + 8);
+        }
+
+        private static ulong ReadPointer(IMemoryManager memory, ulong address)
+        {
+            try
+            {
+                return address == 0 ? 0 : memory.Read<ulong>(address);
+            }
+            catch
+            {
+                return 0;
+            }
+        }
+
+        private static string ToHex(ulong value)
+        {
+            return value == 0 ? "0x0" : "0x" + value.ToString("x", CultureInfo.InvariantCulture);
+        }
+
+        private static ulong[] ParseTargets(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return [];
+            }
+
+            return value
+                .Split([',', ';', ' ', '\n', '\r', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(ParseAddress)
+                .Where(address => address != 0)
+                .Distinct()
+                .ToArray();
+        }
+
+        private static int[] ParseRegisterList(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return [];
+            }
+
+            return value
+                .Split([',', ';', ' ', '\n', '\r', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(item => item.StartsWith("x", StringComparison.OrdinalIgnoreCase) ? item[1..] : item)
+                .Select(item => int.TryParse(item, NumberStyles.Integer, CultureInfo.InvariantCulture, out int register) ? register : -1)
+                .Where(register => register is >= 0 and <= 31)
+                .Distinct()
+                .ToArray();
+        }
+
+        private static ulong NormalizeAddress(ulong address)
+        {
+            return BaseAddress != 0 && address != 0 && address < BaseAddress ? BaseAddress + address : address;
+        }
+
+        private static ulong ParseAddress(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return 0;
+            }
+
+            value = value.Trim();
+            if (value.StartsWith("0x", StringComparison.OrdinalIgnoreCase))
+            {
+                return ulong.TryParse(value[2..], NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong parsed) ? parsed : 0;
+            }
+
+            return ulong.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong decimalParsed)
+                ? decimalParsed
+                : ulong.TryParse(value, NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong hexParsed)
+                    ? hexParsed
+                    : 0;
+        }
+
+        private static int ReadInt(string name, int fallback)
+        {
+            return int.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Integer, CultureInfo.InvariantCulture, out int value) ? value : fallback;
+        }
+
+        private static float ReadFloat(string name, float fallback)
+        {
+            return float.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Float, CultureInfo.InvariantCulture, out float value) ? value : fallback;
+        }
+
+        private static bool ReadBool(string name)
+        {
+            return bool.TryParse(Environment.GetEnvironmentVariable(name), out bool value) && value;
+        }
+
+        private static bool ReadBoolDefault(string name, bool fallback)
+        {
+            string value = Environment.GetEnvironmentVariable(name);
+            return string.IsNullOrWhiteSpace(value) ? fallback : bool.TryParse(value, out bool parsed) && parsed;
+        }
+    }
+}
