+
+            for (int index = 0; index < v.Length; index++)
+            {
+                v[index] = context.GetV(index);
+            }
+
+            SavedContext saved = new(
+                x,
+                v,
+                context.Pstate,
+                context.Fpsr,
+                context.Fpcr,
+                context.TpidrEl0,
+                context.TpidrroEl0,
+                resumeAddress);
