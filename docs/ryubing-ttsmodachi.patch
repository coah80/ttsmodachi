+                try
+                {
+                    Directory.CreateDirectory(Path.GetDirectoryName(Path.GetFullPath(PcmDumpPath)) ?? ".");
+                    using FileStream stream = File.Open(PcmDumpPath, FileMode.Append, FileAccess.Write, FileShare.Read);
+                    for (int index = 0; index < size; index++)
+                    {
+                        stream.WriteByte(memory.Read<byte>(pointer + (ulong)index));
+                    }
+                    _pcmDumpBytes += size;
+                    _pcmDumpRemainingBytes = Math.Max(0, _pcmDumpRemainingBytes - size);
