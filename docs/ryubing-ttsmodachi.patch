+                DumpMemoryRange(memory, probe.ManagerSlot, Path.Combine(RequestDumpDir, prefix + "-manager-slot.bin"));
+                DumpMemoryRange(memory, probe.ManagerRoot, Path.Combine(RequestDumpDir, prefix + "-manager-root.bin"));
+                DumpMemoryRange(memory, probe.ManagerBase, Path.Combine(RequestDumpDir, prefix + "-manager-base.bin"));
+                DumpMemoryRange(memory, probe.GlobalObject, Path.Combine(RequestDumpDir, prefix + "-global-object.bin"));
+                DumpMemoryRange(memory, probe.CapturedObject, Path.Combine(RequestDumpDir, prefix + "-captured-object.bin"));
+                DumpMemoryRange(memory, probe.CapturedWrapper, Path.Combine(RequestDumpDir, prefix + "-captured-wrapper.bin"));
+                DumpMemoryRange(memory, probe.RequestObject, Path.Combine(RequestDumpDir, prefix + "-request-object.bin"));
+                DumpMemoryRange(memory, probe.VoiceContext, Path.Combine(RequestDumpDir, prefix + "-voice-context.bin"));
+            }
