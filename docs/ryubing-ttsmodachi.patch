+            ulong x20,
+            ulong x21,
+            ulong x22,
+            ulong x23,
+            ulong x24,
+            ulong x25,
+            ulong x26,
+            ulong x27,
+            ulong x28,
+            ulong x29,
+            ulong x30)
+        {
+            if (!Enabled || Volatile.Read(ref _eventCount) >= MaxEvents)
+            {
