+            return formats
+                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(value => Enum.TryParse(value, true, out SampleFormat sampleFormat) ? sampleFormat : SampleFormat.Invalid)
+                .Where(sampleFormat => sampleFormat != SampleFormat.Invalid)
