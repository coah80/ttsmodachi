+        private static void DumpPcm(ExecutionContext context, IMemoryManager memory)
+        {
+            if (string.IsNullOrWhiteSpace(PcmDumpPath) || _dispatchCount == 0 || PcmDumpMaxBytes == 0)
+            {
+                return;
+            }
+
+            if ((uint)PcmPointerRegister >= 31 || (uint)PcmSizeRegister >= 31)
+            {
+                return;
+            }
+
+            lock (Lock)
+            {
+                if (_pcmDumpBytes >= PcmDumpMaxBytes || _pcmDumpRemainingBytes <= 0)
+                {
+                    return;
+                }
+
+                ulong pointer = context.GetX(PcmPointerRegister);
+                ulong requestedSize = context.GetX(PcmSizeRegister);
+                int totalRemaining = PcmDumpMaxBytes - _pcmDumpBytes;
+                int requestRemaining = Math.Min(_pcmDumpRemainingBytes, totalRemaining);
+                int size = (int)Math.Min(Math.Min(requestedSize, 0x20000UL), (ulong)requestRemaining);
+                if (pointer == 0 || size <= 0)
+                {
+                    return;
+                }
+
+                try
+                {
+                    Directory.CreateDirectory(Path.GetDirectoryName(Path.GetFullPath(PcmDumpPath)) ?? ".");
+                    using FileStream stream = File.Open(PcmDumpPath, FileMode.Append, FileAccess.Write, FileShare.Read);
+                    for (int index = 0; index < size; index++)
+                    {
+                        stream.WriteByte(memory.Read<byte>(pointer + (ulong)index));
+                    }
+                    _pcmDumpBytes += size;
+                    _pcmDumpRemainingBytes = Math.Max(0, _pcmDumpRemainingBytes - size);
+                    TracePcm(context, memory, pointer, requestedSize, size);
+                }
+                catch
+                {
+                }
+            }
+        }
