diff --git a/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiAudioTrace.cs b/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiAudioTrace.cs
new file mode 100644
index 0000000..7bc8f8f
--- /dev/null
+++ b/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiAudioTrace.cs
@@ -0,0 +1,234 @@
+using Ryujinx.Audio.Common;
+using Ryujinx.Audio.Renderer.Common;
+using System;
+using System.Collections.Generic;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+using System.Runtime.InteropServices;
+using System.Threading;
+using WaveBuffer = Ryujinx.Audio.Renderer.Common.WaveBuffer;
+
+namespace Ryujinx.Audio.Renderer.Dsp
+{
+    internal static class TtsmodachiAudioTrace
+    {
+        private static readonly string TracePath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_AUDIO_TRACE");
+        private static readonly string DumpDir = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_AUDIO_DUMP_DIR");
+        private static readonly int MaxEvents = ReadInt("RYUJINX_TTSMODACHI_AUDIO_TRACE_MAX_EVENTS", 20000);
+        private static readonly float MinPeak = ReadFloat("RYUJINX_TTSMODACHI_AUDIO_TRACE_MIN_PEAK", 0.001f);
+        private static readonly float DumpMaxSeconds = ReadFloat("RYUJINX_TTSMODACHI_AUDIO_DUMP_MAX_SECONDS", 8.0f);
+        private static readonly HashSet<SampleFormat> AllowedFormats = ReadFormats();
+        private static readonly HashSet<int> DumpNodeIds = ReadDumpNodeIds();
+        private static readonly object TraceLock = new();
+        private static readonly object DumpLock = new();
+        private static readonly Dictionary<string, long> DumpSampleCounts = new();
+
+        private static int _eventCount;
+
+        public static void MaybeTrace(
+            string source,
+            int nodeId,
+            uint sourceSampleRate,
+            uint channelIndex,
+            uint channelCount,
+            SampleFormat sampleFormat,
+            float pitch,
+            uint targetSampleRate,
+            Span<float> outputBuffer,
+            ReadOnlySpan<WaveBuffer> waveBuffers,
+            ReadOnlySpan<ulong> waveBufferCpuAddresses,
+            ReadOnlySpan<ulong> waveBufferCpuSizes,
+            VoiceState stateBefore,
+            VoiceState stateAfter)
+        {
+            bool traceEnabled = !string.IsNullOrWhiteSpace(TracePath);
+            bool dumpEnabled = !string.IsNullOrWhiteSpace(DumpDir);
+
+            if ((!traceEnabled && !dumpEnabled) || (AllowedFormats.Count > 0 && !AllowedFormats.Contains(sampleFormat)))
+            {
+                return;
+            }
+
+            float peak = 0.0f;
+            double sumSquares = 0.0;
+
+            for (int i = 0; i < outputBuffer.Length; i++)
+            {
+                float sample = Math.Abs(outputBuffer[i]);
+                peak = Math.Max(peak, sample);
+                sumSquares += sample * sample;
+            }
+
+            if (peak < MinPeak)
+            {
+                return;
+            }
+
+            if (dumpEnabled)
+            {
+                MaybeDump(source, nodeId, targetSampleRate, channelIndex, sampleFormat, outputBuffer);
+            }
+
+            if (traceEnabled)
+            {
+                int eventCount = Interlocked.Increment(ref _eventCount);
+                if (eventCount > MaxEvents)
+                {
+                    return;
+                }
+
+                double rms = Math.Sqrt(sumSquares / Math.Max(outputBuffer.Length, 1));
+                string waveBufferSummary = DescribeWaveBuffers(waveBuffers, waveBufferCpuAddresses, waveBufferCpuSizes, stateBefore);
+                string line = string.Create(
+                    CultureInfo.InvariantCulture,
+                    $"{DateTimeOffset.UtcNow:O},{eventCount},{source},{nodeId},{sourceSampleRate},{targetSampleRate},{channelIndex},{channelCount},{sampleFormat},{pitch:F4},{peak:F6},{rms:F6},{outputBuffer.Length},{stateBefore.WaveBufferIndex},{stateAfter.WaveBufferIndex},{stateBefore.WaveBufferConsumed},{stateAfter.WaveBufferConsumed},{waveBufferSummary}");
+
+                lock (TraceLock)
+                {
+                    Directory.CreateDirectory(Path.GetDirectoryName(Path.GetFullPath(TracePath)) ?? ".");
+                    File.AppendAllText(TracePath, line + Environment.NewLine);
+                }
+            }
+        }
+
+        private static string DescribeWaveBuffers(
+            ReadOnlySpan<WaveBuffer> waveBuffers,
+            ReadOnlySpan<ulong> waveBufferCpuAddresses,
+            ReadOnlySpan<ulong> waveBufferCpuSizes,
+            VoiceState state)
+        {
+            Span<bool> valid = state.IsWaveBufferValid;
+            List<string> parts = [];
+
+            for (int i = 0; i < waveBuffers.Length; i++)
+            {
+                WaveBuffer waveBuffer = waveBuffers[i];
+                bool isValid = i < valid.Length && valid[i];
+                if (!isValid && waveBuffer.Buffer == 0 && waveBuffer.BufferSize == 0)
+                {
+                    continue;
+                }
+
+                ulong cpuAddress = i < waveBufferCpuAddresses.Length ? waveBufferCpuAddresses[i] : 0;
+                ulong cpuSize = i < waveBufferCpuSizes.Length ? waveBufferCpuSizes[i] : 0;
+                string flags = string.Create(
+                    CultureInfo.InvariantCulture,
+                    $"{(isValid ? "v" : "-")}{(waveBuffer.Looping ? "l" : "-")}{(waveBuffer.IsEndOfStream ? "e" : "-")}");
+                parts.Add(string.Create(
+                    CultureInfo.InvariantCulture,
+                    $"{i}:{flags}:0x{cpuAddress:X}:{cpuSize}:0x{waveBuffer.Buffer:X}:{waveBuffer.BufferSize}:0x{waveBuffer.Context:X}:{waveBuffer.ContextSize}:{waveBuffer.StartSampleOffset}-{waveBuffer.EndSampleOffset}:{waveBuffer.LoopStartSampleOffset}-{waveBuffer.LoopEndSampleOffset}:{waveBuffer.LoopCount}"));
+            }
+
+            return parts.Count == 0 ? "-" : string.Join("|", parts);
+        }
+
+        private static void MaybeDump(
+            string source,
+            int nodeId,
+            uint targetSampleRate,
+            uint channelIndex,
+            SampleFormat sampleFormat,
+            Span<float> outputBuffer)
+        {
+            if (DumpNodeIds.Count > 0 && !DumpNodeIds.Contains(nodeId))
+            {
+                return;
+            }
+
+            string key = string.Create(
+                CultureInfo.InvariantCulture,
+                $"{Sanitize(source)}-{nodeId}-{targetSampleRate}-{sampleFormat}-ch{channelIndex}");
+            string path = Path.Combine(DumpDir, key + ".s16le");
+            string metaPath = Path.Combine(DumpDir, key + ".txt");
+
+            lock (DumpLock)
+            {
+                long existingSamples = DumpSampleCounts.TryGetValue(key, out long count) ? count : 0;
+                long maxSamples = DumpMaxSeconds <= 0 ? long.MaxValue : (long)(targetSampleRate * DumpMaxSeconds);
+
+                if (existingSamples >= maxSamples)
+                {
+                    return;
+                }
+
+                int samplesToWrite = (int)Math.Min(outputBuffer.Length, maxSamples - existingSamples);
+                Span<short> samples = stackalloc short[samplesToWrite];
+
+                for (int i = 0; i < samplesToWrite; i++)
+                {
+                    float value = outputBuffer[i];
+                    int sample = Math.Abs(value) <= 1.5f
+                        ? (int)MathF.Round(value * short.MaxValue)
+                        : (int)MathF.Round(value);
+
+                    samples[i] = (short)Math.Clamp(sample, short.MinValue, short.MaxValue);
+                }
+
+                Directory.CreateDirectory(DumpDir);
+                if (!File.Exists(metaPath))
+                {
+                    File.WriteAllText(metaPath, $"sample_rate={targetSampleRate}{Environment.NewLine}format=s16le{Environment.NewLine}channels=1{Environment.NewLine}");
+                }
+
+                using FileStream stream = File.Open(path, FileMode.Append, FileAccess.Write, FileShare.Read);
+                stream.Write(MemoryMarshal.AsBytes(samples));
+                DumpSampleCounts[key] = existingSamples + samplesToWrite;
+            }
+        }
+
+        private static int ReadInt(string name, int fallback)
+        {
+            return int.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Integer, CultureInfo.InvariantCulture, out int value)
+                ? value
+                : fallback;
+        }
+
+        private static float ReadFloat(string name, float fallback)
+        {
+            return float.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Float, CultureInfo.InvariantCulture, out float value)
+                ? value
+                : fallback;
+        }
+
+        private static HashSet<SampleFormat> ReadFormats()
+        {
+            string formats = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_AUDIO_TRACE_FORMATS");
