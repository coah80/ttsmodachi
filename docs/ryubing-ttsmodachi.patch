+                byte readyFlag = memory.Read<byte>(candidate + ReadyFlagOffset);
+                int textLength = memory.Read<int>(candidate + TextLengthOffset);
+                bool ready = voiceContext != 0;
+                probe = new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, candidate, voiceContext, readyFlag, textLength, ready ? "ready" : "no-voice-context", ready);
+                return true;
+            }
+            catch
+            {
+                probe = new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, candidate, 0, 0, 0, "candidate-read-failed", false);
+                return true;
