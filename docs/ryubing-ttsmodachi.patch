+        private static int EstimatePcmBytes(int textByteLength)
+        {
+            float seconds = Math.Clamp(textByteLength / PcmCaptureTextBytesPerSecond, PcmMinSeconds, PcmMaxSeconds);
+            int bytes = (int)Math.Ceiling(PcmSampleRate * 2.0 * seconds);
+            return bytes % 2 == 0 ? bytes : bytes + 1;
+        }
