+using System;
+using System.Collections.Concurrent;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+using System.Threading;
+
+namespace ARMeilleure.Translation
+{
+    public static class TtsmodachiMemoryWriteTrace
+    {
+        private static readonly string TracePath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_MEMORY_WRITE_TRACE");
+        private static readonly ulong BaseAddress = ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_GUEST_TRACE_BASE"));
+        private static readonly AddressRange[] Ranges = ParseRanges(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_MEMORY_WRITE_RANGES"));
+        private static readonly int MaxEvents = int.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_MEMORY_WRITE_MAX_EVENTS"), NumberStyles.Integer, CultureInfo.InvariantCulture, out int maxEvents) ? maxEvents : 20000;
+        private static readonly DateTimeOffset StartedAt = DateTimeOffset.UtcNow;
+        private static readonly double StartDelaySeconds = ParseDouble(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_MEMORY_WRITE_START_SECONDS"));
+        private static readonly double DurationSeconds = ParseDouble(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_MEMORY_WRITE_DURATION_SECONDS"));
+        private static readonly ConcurrentDictionary<ulong, int> SourceCounts = new();
+        private static readonly object FileLock = new();
+        private static int _eventCount;
+
+        public static bool Enabled => !string.IsNullOrWhiteSpace(TracePath) && Ranges.Length > 0;
+
+        public static void MaybeTrace(
+            ulong address,
+            ulong size,
+            ulong sourcePc,
+            ulong linkRegister,
+            ulong register0,
+            ulong register1,
+            ulong register2)
+        {
+            if (!Enabled || !IsInTraceWindow() || Volatile.Read(ref _eventCount) >= MaxEvents || !Matches(address, size))
+            {
+                return;
+            }
+
+            int eventCount = Interlocked.Increment(ref _eventCount);
+            int sourceCount = SourceCounts.AddOrUpdate(sourcePc, 1, (_, count) => count + 1);
+            ulong relativeSourcePc = BaseAddress != 0 && sourcePc >= BaseAddress ? sourcePc - BaseAddress : sourcePc;
+            ulong relativeLinkRegister = BaseAddress != 0 && linkRegister >= BaseAddress ? linkRegister - BaseAddress : linkRegister;
+            string line = string.Join(
+                ',',
+                DateTimeOffset.UtcNow.ToString("O", CultureInfo.InvariantCulture),
+                eventCount.ToString(CultureInfo.InvariantCulture),
+                $"0x{address:x}",
+                size.ToString(CultureInfo.InvariantCulture),
+                $"0x{sourcePc:x}",
+                $"0x{relativeSourcePc:x}",
+                $"0x{linkRegister:x}",
+                $"0x{relativeLinkRegister:x}",
+                $"0x{register0:x}",
+                $"0x{register1:x}",
+                $"0x{register2:x}",
+                sourceCount.ToString(CultureInfo.InvariantCulture));
+
+            lock (FileLock)
+            {
+                bool writeHeader = !File.Exists(TracePath);
+                using StreamWriter writer = File.AppendText(TracePath);
+                if (writeHeader)
+                {
+                    writer.WriteLine("utc,event_count,address,size,source_pc,relative_source_pc,link_register,relative_link_register,x0,x1,x2,source_count");
+                }
+
+                writer.WriteLine(line);
+            }
+        }
+
+        private static bool Matches(ulong address, ulong size)
+        {
+            ulong end = address + Math.Max(size, 1);
+            foreach (AddressRange range in Ranges)
+            {
+                if (address < range.End && end > range.Start)
+                {
+                    return true;
+                }
+            }
+
+            return false;
+        }
+
+        private static bool IsInTraceWindow()
+        {
+            double elapsedSeconds = (DateTimeOffset.UtcNow - StartedAt).TotalSeconds;
+            if (StartDelaySeconds > 0 && elapsedSeconds < StartDelaySeconds)
+            {
+                return false;
+            }
+
+            return DurationSeconds <= 0 || elapsedSeconds <= StartDelaySeconds + DurationSeconds;
+        }
+
+        private static AddressRange[] ParseRanges(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return [];
+            }
+
+            return value
+                .Split([',', ';', ' ', '\n', '\r', '\t'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(ParseRange)
+                .Where(range => range.Enabled)
+                .Distinct()
+                .ToArray();
+        }
+
+        private static AddressRange ParseRange(string value)
+        {
+            string[] parts = value.Split(['-', ':'], 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
+            if (parts.Length != 2)
+            {
+                return default;
+            }
+
+            ulong start = ParseAddress(parts[0]);
+            ulong end = ParseAddress(parts[1]);
+            if (end < start)
+            {
+                (start, end) = (end, start);
+            }
+
+            if (start == end)
+            {
+                return default;
+            }
+
+            return new AddressRange(start, end, true);
+        }
+
+        private static double ParseDouble(string value)
+        {
+            return double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out double parsed) ? parsed : 0;
+        }
+
+        private static ulong ParseAddress(string value)
+        {
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return 0;
+            }
+
+            value = value.Trim();
+            if (value.StartsWith("0x", StringComparison.OrdinalIgnoreCase))
+            {
+                return ulong.TryParse(value[2..], NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong parsed) ? parsed : 0;
+            }
+
+            return ulong.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong decimalParsed)
+                ? decimalParsed
+                : ulong.TryParse(value, NumberStyles.HexNumber, CultureInfo.InvariantCulture, out ulong hexParsed)
+                    ? hexParsed
+                    : 0;
+        }
+
+        private readonly record struct AddressRange(ulong Start, ulong End, bool Enabled);
+    }
+}
diff --git a/src/ARMeilleure/Translation/TtsmodachiTextInject.cs b/src/ARMeilleure/Translation/TtsmodachiTextInject.cs
