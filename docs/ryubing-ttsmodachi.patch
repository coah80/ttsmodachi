+                manifest.WriteLine(string.Create(CultureInfo.InvariantCulture, $"captured_object={ToHex(probe.CapturedObject)}"));
+                manifest.WriteLine(string.Create(CultureInfo.InvariantCulture, $"captured_wrapper={ToHex(probe.CapturedWrapper)}"));
+                manifest.WriteLine(string.Create(CultureInfo.InvariantCulture, $"request_object={ToHex(probe.RequestObject)}"));
+                manifest.WriteLine(string.Create(CultureInfo.InvariantCulture, $"voice_context={ToHex(probe.VoiceContext)}"));
