+        private static bool TryKickConsumer(ExecutionContext context, IMemoryManager memory, ulong address, ulong ttsObject, RequestProbe probe, ulong resumeAddress, string reason, out ulong consumerAddress)
+        {
+            consumerAddress = 0;
+            ApplyMemoryPatches(memory, address, reason, ttsObject, probe);
+            SavedConsumerCall saved;
+            lock (Lock)
+            {
+                if (!CanKickConsumerNow())
+                {
+                    return false;
+                }
+
+                saved = _savedConsumerCall;
+                _consumerKickCount++;
+                _lastConsumerKickAt = DateTime.UtcNow;
+            }
+
+            SaveContext(context, resumeAddress);
+            for (int index = 0; index < 29; index++)
+            {
+                context.SetX(index, saved.X[index]);
+            }
+
+            for (int index = 0; index < saved.V.Length; index++)
+            {
+                context.SetV(index, saved.V[index]);
+            }
+
+            context.SetX(30, TrampolineReturnAddress);
+            consumerAddress = ConsumerKickAddress;
+            Trace(memory, address, "consumer", reason, ttsObject, 0, probe);
+            return true;
+        }
+
+        private static void ApplyMemoryPatches(IMemoryManager memory, ulong address, string phase, ulong ttsObject, RequestProbe probe)
+        {
+            if (string.IsNullOrWhiteSpace(MemoryPatchFile))
+            {
+                return;
+            }
+
+            lock (Lock)
+            {
+                if (MemoryPatchOnce && _memoryPatchApplied)
+                {
+                    return;
+                }
+
+                _memoryPatchApplied = true;
+            }
+
+            try
+            {
+                int patches = 0;
+                foreach (string rawLine in File.ReadAllLines(MemoryPatchFile))
+                {
+                    string line = rawLine.Split('#', 2)[0].Trim();
+                    if (string.IsNullOrWhiteSpace(line))
+                    {
+                        continue;
+                    }
+
+                    string[] parts = line.Split(['=', ' ', '\t'], 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
+                    if (parts.Length != 2)
+                    {
+                        continue;
+                    }
+
+                    ulong target = ParseAddress(parts[0]);
+                    if (target == 0 || !File.Exists(parts[1]))
+                    {
+                        continue;
+                    }
+
+                    byte[] data = File.ReadAllBytes(parts[1]);
+                    for (int index = 0; index < data.Length; index++)
+                    {
+                        memory.Write<byte>(target + (ulong)index, data[index]);
+                    }
+
+                    patches++;
+                }
+
+                Trace(memory, address, "memory-patch", $"phase={phase} patches={patches}", ttsObject, 0, probe);
+            }
+            catch (Exception exception)
+            {
+                Trace(memory, address, "memory-patch", "failed " + exception.GetType().Name, ttsObject, 0, probe);
+            }
+        }
+
+        private static void LoadConsumerFrame()
+        {
+            if (!ConsumerFrameLoad || string.IsNullOrWhiteSpace(ConsumerFrameFile))
+            {
+                return;
+            }
+
+            try
+            {
+                if (!File.Exists(ConsumerFrameFile))
+                {
+                    return;
+                }
+
+                string content = File.ReadAllText(ConsumerFrameFile);
+                if (!TryParseConsumerFrame(content, out ulong[] x))
+                {
+                    return;
+                }
+
+                V128[] v = new V128[32];
+                for (int index = 0; index < v.Length; index++)
+                {
+                    v[index] = V128.Zero;
+                }
+
+                _savedConsumerCall = new SavedConsumerCall(x, v);
+                _hasSavedConsumerCall = true;
+            }
+            catch
+            {
+            }
+        }
+
+        private static void SaveConsumerFrame(ulong[] x)
+        {
+            if (!ConsumerFrameSave || string.IsNullOrWhiteSpace(ConsumerFrameFile))
+            {
+                return;
+            }
+
