+        private static bool CanKickConsumerNow()
+        {
+            return ConsumerKickAddress != 0 &&
+                ConsumerKickMax > 0 &&
+                _consumerKickCount < ConsumerKickMax &&
+                _hasSavedConsumerCall &&
+                (ConsumerKickIntervalMs == 0 || (DateTime.UtcNow - _lastConsumerKickAt).TotalMilliseconds >= ConsumerKickIntervalMs);
