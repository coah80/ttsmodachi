diff --git a/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiSinkCapture.cs b/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiSinkCapture.cs
new file mode 100644
index 0000000..ffe7122
--- /dev/null
+++ b/src/Ryujinx.Audio/Renderer/Dsp/TtsmodachiSinkCapture.cs
@@ -0,0 +1,100 @@
+using System;
+using System.Buffers.Binary;
+using System.Globalization;
+using System.IO;
+using System.Runtime.InteropServices;
+using System.Threading;
+
+namespace Ryujinx.Audio.Renderer.Dsp
+{
+    internal static class TtsmodachiSinkCapture
+    {
+        private static readonly string DumpDir = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_OUTPUT_CAPTURE_DIR");
+        private static readonly string TracePath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_OUTPUT_CAPTURE_TRACE");
+        private static readonly int MaxEvents = ReadInt("RYUJINX_TTSMODACHI_OUTPUT_CAPTURE_MAX_EVENTS", 20000);
+        private static readonly int MinPeak = ReadInt("RYUJINX_TTSMODACHI_OUTPUT_CAPTURE_MIN_PEAK", 128);
+        private static readonly object CaptureLock = new();
+        private static int _eventCount;
+
+        public static void MaybeCapture(uint sampleRate, uint channelCount, ReadOnlySpan<short> interleavedSamples)
+        {
+            if ((string.IsNullOrWhiteSpace(DumpDir) && string.IsNullOrWhiteSpace(TracePath)) || channelCount == 0 || interleavedSamples.IsEmpty)
+            {
+                return;
+            }
+
+            int eventCount = Interlocked.Increment(ref _eventCount);
+            if (eventCount > MaxEvents)
+            {
+                return;
+            }
+
+            short[] monoSamples = DownmixToMono(interleavedSamples, (int)channelCount);
+            int peak = 0;
+            double sumSquares = 0;
+            for (int i = 0; i < monoSamples.Length; i++)
+            {
+                int sample = Math.Abs(monoSamples[i]);
+                peak = Math.Max(peak, sample);
+                sumSquares += sample * sample;
+            }
+
+            if (peak < MinPeak)
+            {
+                return;
+            }
+
+            double rms = Math.Sqrt(sumSquares / Math.Max(monoSamples.Length, 1));
+            string path = "";
+            lock (CaptureLock)
+            {
+                if (!string.IsNullOrWhiteSpace(DumpDir))
+                {
+                    Directory.CreateDirectory(DumpDir);
+                    path = Path.Combine(DumpDir, string.Create(CultureInfo.InvariantCulture, $"SinkBuffer-{eventCount:D05}-{sampleRate}-mono.s16le"));
+                    File.WriteAllBytes(path, MemoryMarshal.AsBytes(monoSamples.AsSpan()).ToArray());
+                }
+
+                if (!string.IsNullOrWhiteSpace(TracePath))
+                {
+                    Directory.CreateDirectory(Path.GetDirectoryName(Path.GetFullPath(TracePath)) ?? ".");
+                    bool writeHeader = !File.Exists(TracePath);
+                    using StreamWriter writer = File.AppendText(TracePath);
+                    if (writeHeader)
+                    {
+                        writer.WriteLine("utc,event_count,buffer_tag,sample_rate,channel_count,sample_format,input_bytes,output_samples,peak,rms,path");
+                    }
+
+                    writer.WriteLine(string.Create(
+                        CultureInfo.InvariantCulture,
+                        $"{DateTimeOffset.UtcNow:O},{eventCount},0x{eventCount:x},{sampleRate},{channelCount},PcmInt16,{interleavedSamples.Length * sizeof(short)},{monoSamples.Length},{peak},{rms:F3},{path}"));
+                }
+            }
+        }
+
+        private static short[] DownmixToMono(ReadOnlySpan<short> interleavedSamples, int channelCount)
+        {
+            int frameCount = interleavedSamples.Length / channelCount;
+            short[] output = new short[frameCount];
+            for (int frame = 0; frame < frameCount; frame++)
+            {
+                int sum = 0;
+                for (int channel = 0; channel < channelCount; channel++)
+                {
+                    sum += interleavedSamples[frame * channelCount + channel];
+                }
+
+                output[frame] = (short)Math.Clamp(sum / channelCount, short.MinValue, short.MaxValue);
+            }
+
+            return output;
+        }
+
+        private static int ReadInt(string name, int fallback)
+        {
+            return int.TryParse(Environment.GetEnvironmentVariable(name), NumberStyles.Integer, CultureInfo.InvariantCulture, out int value)
+                ? value
+                : fallback;
+        }
+    }
+}
