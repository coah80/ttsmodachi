+            }
+
+            if (TryProbeCandidate(memory, wrapperRequestObject, managerSlot, managerRoot, managerBase, globalObject, out RequestProbe wrapperProbe))
+            {
+                return wrapperProbe;
+            }
+
+            if (TryProbeCandidate(memory, globalObject, managerSlot, managerRoot, managerBase, globalObject, out RequestProbe globalProbe))
+            {
+                return globalProbe;
