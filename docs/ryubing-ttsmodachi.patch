+        private static RequestProbe ProbeRequestObject(IMemoryManager memory)
+        {
+            ulong managerSlot = 0;
+            ulong managerRoot = 0;
+            ulong managerBase = 0;
+            ulong globalObject = 0;
+            ulong wrapperRequestObject = 0;
+
+            try
+            {
+                if (DispatchWrapper && _wrapperObject != 0)
+                {
+                    wrapperRequestObject = memory.Read<ulong>(_wrapperObject);
+                }
+
+                if (ManagerGlobalAddress != 0)
+                {
+                    managerSlot = memory.Read<ulong>(ManagerGlobalAddress);
+                    if (managerSlot != 0)
+                    {
+                        managerRoot = memory.Read<ulong>(managerSlot);
+                        if (managerRoot != 0)
+                        {
+                            managerBase = memory.Read<ulong>(managerRoot + ManagerInnerOffset);
+                            if (managerBase != 0)
+                            {
+                                globalObject = managerBase + RequestObjectOffset;
+                            }
+                        }
+                    }
+                }
+            }
+            catch
+            {
+                return new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, 0, 0, 0, 0, "manager-read-failed", false);
+            }
+
+            if (TryProbeCandidate(memory, wrapperRequestObject, managerSlot, managerRoot, managerBase, globalObject, out RequestProbe wrapperProbe))
+            {
+                return wrapperProbe;
+            }
+
+            if (TryProbeCandidate(memory, globalObject, managerSlot, managerRoot, managerBase, globalObject, out RequestProbe globalProbe))
+            {
+                return globalProbe;
+            }
+
+            if (TryProbeCandidate(memory, _ttsObject, managerSlot, managerRoot, managerBase, globalObject, out RequestProbe capturedProbe))
+            {
+                return capturedProbe;
+            }
+
+            string reason = globalObject == 0 && _ttsObject == 0 ? "no-object" : "object-not-ready";
+            return new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, 0, 0, 0, 0, reason, false);
+        }
+
+        private static bool TryProbeCandidate(IMemoryManager memory, ulong candidate, ulong managerSlot, ulong managerRoot, ulong managerBase, ulong globalObject, out RequestProbe probe)
+        {
+            probe = default;
+            if (candidate == 0)
+            {
+                return false;
+            }
+
+            try
+            {
+                ulong voiceContext = memory.Read<ulong>(candidate + VoiceContextOffset);
+                byte readyFlag = memory.Read<byte>(candidate + ReadyFlagOffset);
+                int textLength = memory.Read<int>(candidate + TextLengthOffset);
+                bool ready = voiceContext != 0;
+                probe = new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, candidate, voiceContext, readyFlag, textLength, ready ? "ready" : "no-voice-context", ready);
+                return true;
+            }
+            catch
+            {
+                probe = new RequestProbe(managerSlot, managerRoot, managerBase, globalObject, _ttsObject, _wrapperObject, candidate, 0, 0, 0, "candidate-read-failed", false);
+                return true;
+            }
+        }
