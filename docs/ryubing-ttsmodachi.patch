+        private static bool AlreadyDumpedPhase(string phase)
+        {
+            return string.Equals(phase, "dispatch", StringComparison.OrdinalIgnoreCase)
+                ? _dumpedRequestDispatch
+                : _dumpedRequestReady;
+        }
