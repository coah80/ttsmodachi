+        private static SavedContext BuildSavedContext(ExecutionContext context, ulong resumeAddress)
+        {
+            ulong[] x = new ulong[32];
+            V128[] v = new V128[32];
+
+            for (int index = 0; index < x.Length; index++)
+            {
+                x[index] = context.GetX(index);
+            }
+
+            for (int index = 0; index < v.Length; index++)
+            {
+                v[index] = context.GetV(index);
+            }
+
+            SavedContext saved = new(
+                x,
+                v,
+                context.Pstate,
+                (uint)context.Fpsr,
+                (uint)context.Fpcr,
+                context.TpidrEl0,
+                context.TpidrroEl0,
+                resumeAddress);
+
+            return saved;
+        }
