+        private static string FormatConsumerFrame(ulong[] x)
+        {
+            StringBuilder builder = new();
+            for (int index = 0; index < Math.Min(29, x.Length); index++)
+            {
+                if (index != 0)
+                {
+                    builder.Append(' ');
+                }
+
+                builder.Append('x');
+                builder.Append(index.ToString(CultureInfo.InvariantCulture));
+                builder.Append('=');
+                builder.Append(ToHex(x[index]));
+            }
+
+            builder.AppendLine();
+            return builder.ToString();
+        }
+
+        private static bool TryParseConsumerFrame(string content, out ulong[] x)
+        {
+            x = new ulong[31];
+            bool foundAny = false;
+            foreach (string part in content.Split([' ', '\n', '\r', '\t', ','], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
+            {
+                int equals = part.IndexOf('=');
+                if (equals <= 1 || part[0] != 'x')
+                {
+                    continue;
+                }
+
+                if (!int.TryParse(part[1..equals], NumberStyles.Integer, CultureInfo.InvariantCulture, out int register) || register < 0 || register >= 29)
+                {
+                    continue;
+                }
+
+                ulong value = ParseAddress(part[(equals + 1)..]);
+                x[register] = value;
+                foundAny = true;
+            }
+
+            return foundAny;
+        }
