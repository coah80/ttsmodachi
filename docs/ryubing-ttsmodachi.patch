+        private static readonly int MaxBytes = Math.Clamp(ReadInt("RYUJINX_TTSMODACHI_APPLIANCE_TEXT_MAX_BYTES", DefaultMaxBytes), 1, 512);
+        private static readonly ulong ManagerGlobalAddress = NormalizeAddress(ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_APPLIANCE_MANAGER_GLOBAL_ADDR") ?? "0x32ccde0"));
+        private static readonly ulong ManagerInnerOffset = ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_APPLIANCE_MANAGER_INNER_OFFSET") ?? "0xda0");
