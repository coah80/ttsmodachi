+        private static bool Matches(ulong address, ulong[] targets)
+        {
+            foreach (ulong target in targets)
+            {
+                if (address == target)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && address >= BaseAddress && address - BaseAddress == target)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && target < BaseAddress && address == BaseAddress + target)
+                {
+                    return true;
+                }
+            }
+
+            return false;
+        }
