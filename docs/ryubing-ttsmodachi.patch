+        private static void EmitTtsmodachiAppliance(ArmEmitterContext context, ulong address)
+        {
+            if (!TtsmodachiAppliance.ShouldHook(address))
+            {
+                return;
+            }
+
+            context.StoreToContext();
+            Operand dispatchAddress = context.Call(
+                typeof(TtsmodachiAppliance).GetMethod(nameof(TtsmodachiAppliance.MaybeDispatchFromContext)),
+                Const(address));
+
+            Operand lblContinue = Label();
+            context.BranchIf(lblContinue, dispatchAddress, Const(0UL), Comparison.Equal);
+
+            context.LoadFromContext();
+            InstEmitFlowHelper.EmitVirtualJump(context, dispatchAddress, isReturn: false);
+
+            context.MarkLabel(lblContinue);
+            context.LoadFromContext();
+        }
+
+        private static Operand TraceRegister(int regIndex)
+        {
+            return Register(regIndex, RegisterType.Integer, OperandType.I64);
+        }
+
+        private static void EmitTtsmodachiTextInject(ArmEmitterContext context, ulong address)
+        {
+            if (!TtsmodachiTextInject.Enabled || !TtsmodachiTextInject.Matches(address))
+            {
+                return;
+            }
+
+            if (TtsmodachiTextInject.UsesPointer)
+            {
+                context.Copy(Register(2, RegisterType.Integer, OperandType.I64), Const(TtsmodachiTextInject.Pointer));
+                context.Copy(Register(3, RegisterType.Integer, OperandType.I64), Const((ulong)TtsmodachiTextInject.Length));
+                return;
+            }
+
+            Operand textPointer = Register(2, RegisterType.Integer, OperandType.I64);
+            byte[] bytes = TtsmodachiTextInject.TextBytes;
+            for (int index = 0; index < bytes.Length; index++)
+            {
+                Operand guestAddress = index == 0 ? textPointer : context.Add(textPointer, Const((ulong)index));
+                Operand physicalAddress = InstEmitMemoryHelper.EmitPtPointerLoad(context, guestAddress, default, write: true, size: 0);
+                context.Store8(physicalAddress, Const((int)bytes[index]));
+            }
+
+            Operand terminatorAddress = context.Add(textPointer, Const((ulong)bytes.Length));
+            Operand terminatorPhysicalAddress = InstEmitMemoryHelper.EmitPtPointerLoad(context, terminatorAddress, default, write: true, size: 0);
+            context.Store8(terminatorPhysicalAddress, Const(0));
+            context.Copy(Register(3, RegisterType.Integer, OperandType.I64), Const((ulong)bytes.Length));
+        }
