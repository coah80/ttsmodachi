+            if (bool.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_DISABLE_HYPERVISOR"), out bool disableHypervisor) && disableHypervisor)
+            {
+                return false;
+            }
+
+            return configuredUseHypervisor;
+        }
+
+        private static bool UseTtsmodachiDummyAudio()
+        {
+            return bool.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_DUMMY_AUDIO"), out bool dummyAudio) && dummyAudio;
+        }
+
+        private static IHardwareDeviceDriver CreateTtsmodachiAudioDriver()
+        {
+            if (UseTtsmodachiDummyAudio())
+            {
+                Logger.Info?.Print(LogClass.Audio, "TTSmodachi dummy audio driver enabled.");
+                return new DummyHardwareDeviceDriver();
+            }
+
+            return new SDL3HardwareDeviceDriver();
+        }
     }
 }
diff --git a/src/Ryujinx/Headless/TtsmodachiHeadlessTouch.cs b/src/Ryujinx/Headless/TtsmodachiHeadlessTouch.cs
new file mode 100644
index 0000000..ac7efaf
--- /dev/null
+++ b/src/Ryujinx/Headless/TtsmodachiHeadlessTouch.cs
@@ -0,0 +1,129 @@
+using Ryujinx.HLE.HOS.Services.Hid;
+using Ryujinx.HLE.HOS.Services.Hid.Types.SharedMemory.TouchScreen;
+using System;
+using System.Globalization;
+using System.IO;
+using System.Linq;
+
+namespace Ryujinx.Headless
+{
+    internal static class TtsmodachiHeadlessTouch
+    {
+        private static readonly TouchEvent[] Script = ParseScript(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TOUCH_SCRIPT"));
+        private static readonly string LiveScriptPath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_TOUCH_FILE");
+        private const int LiveScriptCheckFrames = 30;
+        private static ulong _lastLiveScriptCheckFrame;
+        private static long _liveScriptLastWriteTicks;
+        private static TouchEvent[] _liveScript = [];
+
+        public static bool TryGetTouch(ulong frame, out TouchPoint touchPoint)
+        {
+            foreach (TouchEvent touchEvent in GetEvents(frame))
+            {
+                if (frame < touchEvent.StartFrame || frame >= touchEvent.StartFrame + touchEvent.DurationFrames)
+                {
+                    continue;
+                }
+
+                touchPoint = new TouchPoint
+                {
+                    Attribute = frame == touchEvent.StartFrame ? TouchAttribute.Start : TouchAttribute.None,
+                    X = touchEvent.X,
+                    Y = touchEvent.Y,
+                    DiameterX = 8,
+                    DiameterY = 8,
+                };
+                return true;
+            }
+
+            touchPoint = default;
+            return false;
+        }
+
+        private static TouchEvent[] GetEvents(ulong frame)
+        {
+            TouchEvent[] liveScript = GetLiveScript(frame);
+            if (liveScript.Length == 0)
+            {
+                return Script;
+            }
+
+            TouchEvent[] events = new TouchEvent[Script.Length + liveScript.Length];
+            Script.CopyTo(events, 0);
+            liveScript.CopyTo(events, Script.Length);
+            return events;
+        }
+
+        private static TouchEvent[] GetLiveScript(ulong frame)
+        {
+            if (string.IsNullOrWhiteSpace(LiveScriptPath) || frame - _lastLiveScriptCheckFrame < LiveScriptCheckFrames)
+            {
+                return _liveScript;
+            }
+
+            _lastLiveScriptCheckFrame = frame;
+
+            try
+            {
+                FileInfo fileInfo = new(LiveScriptPath);
+                if (!fileInfo.Exists)
+                {
+                    _liveScript = [];
+                    _liveScriptLastWriteTicks = 0;
+                    return _liveScript;
+                }
+
+                long ticks = fileInfo.LastWriteTimeUtc.Ticks;
+                if (ticks == _liveScriptLastWriteTicks)
+                {
+                    return _liveScript;
+                }
+
+                _liveScript = ParseScript(File.ReadAllText(LiveScriptPath));
+                _liveScriptLastWriteTicks = ticks;
+            }
+            catch
+            {
+                _liveScript = [];
+            }
+
+            return _liveScript;
+        }
+
+        private static TouchEvent[] ParseScript(string script)
+        {
+            if (string.IsNullOrWhiteSpace(script))
+            {
+                return [];
+            }
+
+            return script
+                .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
+                .Select(ParseEvent)
+                .Where(touchEvent => touchEvent.DurationFrames > 0)
+                .ToArray();
+        }
+
+        private static TouchEvent ParseEvent(string value)
+        {
+            string[] parts = value.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
+            if (parts.Length < 3 ||
+                !ulong.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out ulong startFrame) ||
+                !uint.TryParse(parts[1], NumberStyles.Integer, CultureInfo.InvariantCulture, out uint x) ||
+                !uint.TryParse(parts[2], NumberStyles.Integer, CultureInfo.InvariantCulture, out uint y))
+            {
+                return default;
+            }
+
+            ulong durationFrames = 6;
+            if (parts.Length >= 4)
+            {
+                ulong.TryParse(parts[3], NumberStyles.Integer, CultureInfo.InvariantCulture, out durationFrames);
+            }
+
+            return new TouchEvent(startFrame, Math.Max(durationFrames, 1), x, y);
+        }
+
+        private readonly record struct TouchEvent(ulong StartFrame, ulong DurationFrames, uint X, uint Y);
+    }
+}
