+using System.Threading;
+
+namespace ARMeilleure.Translation
+{
+    public static class TtsmodachiBlockTrace
+    {
+        private static readonly string TracePath = Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_BLOCK_TRACE");
+        private static readonly ulong BaseAddress = ParseAddress(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_GUEST_TRACE_BASE"));
+        private static readonly ulong[] TargetAddresses = ParseTargets(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_BLOCK_TRACE_ADDRS"));
+        private static readonly int MaxEvents = int.TryParse(Environment.GetEnvironmentVariable("RYUJINX_TTSMODACHI_BLOCK_TRACE_MAX_EVENTS"), NumberStyles.Integer, CultureInfo.InvariantCulture, out int maxEvents) ? maxEvents : 50000;
+        private static readonly ConcurrentDictionary<ulong, int> Counts = new();
+        private static readonly object FileLock = new();
+        private static int _eventCount;
+
+        public static bool Enabled => !string.IsNullOrWhiteSpace(TracePath) && TargetAddresses.Length > 0;
+
+        public static bool Matches(ulong address)
+        {
+            foreach (ulong targetAddress in TargetAddresses)
+            {
+                if (address == targetAddress)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && address >= BaseAddress && address - BaseAddress == targetAddress)
+                {
+                    return true;
+                }
+
+                if (BaseAddress != 0 && targetAddress < BaseAddress && address == BaseAddress + targetAddress)
+                {
+                    return true;
+                }
+            }
+
+            return false;
+        }
+
+        public static void MaybeTrace(
+            ulong address,
+            ulong x0,
+            ulong x1,
+            ulong x2,
+            ulong x3,
+            ulong x4,
+            ulong x5,
