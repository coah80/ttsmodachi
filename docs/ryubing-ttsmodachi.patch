+        private static void ApplyMemoryPatches(IMemoryManager memory, ulong address, string phase, ulong ttsObject, RequestProbe probe)
+        {
+            if (string.IsNullOrWhiteSpace(MemoryPatchFile))
+            {
+                return;
+            }
+
+            lock (Lock)
+            {
+                if (MemoryPatchOnce && _memoryPatchApplied)
+                {
+                    return;
+                }
+
+                _memoryPatchApplied = true;
+            }
+
+            try
+            {
+                int patches = 0;
+                foreach (string rawLine in File.ReadAllLines(MemoryPatchFile))
+                {
+                    string line = rawLine.Split('#', 2)[0].Trim();
+                    if (string.IsNullOrWhiteSpace(line))
+                    {
+                        continue;
+                    }
+
+                    string[] parts = line.Split(['=', ' ', '\t'], 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
+                    if (parts.Length != 2)
+                    {
+                        continue;
+                    }
+
+                    ulong target = ParseAddress(parts[0]);
+                    if (target == 0 || !File.Exists(parts[1]))
+                    {
+                        continue;
+                    }
+
+                    byte[] data = File.ReadAllBytes(parts[1]);
+                    for (int index = 0; index < data.Length; index++)
+                    {
+                        memory.Write<byte>(target + (ulong)index, data[index]);
+                    }
+
+                    patches++;
+                }
+
+                Trace(memory, address, "memory-patch", $"phase={phase} patches={patches}", ttsObject, 0, probe);
+            }
+            catch (Exception exception)
+            {
+                Trace(memory, address, "memory-patch", "failed " + exception.GetType().Name, ttsObject, 0, probe);
+            }
+        }
