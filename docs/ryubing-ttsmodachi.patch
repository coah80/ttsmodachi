+        private static void MarkDumpedPhase(string phase)
+        {
+            if (string.Equals(phase, "dispatch", StringComparison.OrdinalIgnoreCase))
+            {
+                _dumpedRequestDispatch = true;
+                return;
+            }
+
+            _dumpedRequestReady = true;
