+            lock (Lock)
+            {
+                dumpIndex = _consumerDumpCount++;
+            }
+
+            try
+            {
+                Directory.CreateDirectory(ConsumerDumpDir);
+                foreach (int register in ConsumerDumpRegisters)
+                {
+                    if ((uint)register >= x.Length)
+                    {
+                        continue;
+                    }
+
+                    ulong pointer = x[register];
+                    if (pointer == 0)
+                    {
+                        continue;
+                    }
+
+                    byte[] data = new byte[ConsumerDumpBytes];
+                    for (int index = 0; index < data.Length; index++)
+                    {
+                        data[index] = memory.Read<byte>(pointer + (ulong)index);
+                    }
+
+                    string fileName = string.Create(
+                        CultureInfo.InvariantCulture,
+                        $"consumer-{dumpIndex:000000}-pc-{address:x}-x{register:00}-{pointer:x}.bin");
+                    File.WriteAllBytes(Path.Combine(ConsumerDumpDir, fileName), data);
+                }
+            }
+            catch
+            {
+            }
+        }
