+            }
+
+            int eventCount = Interlocked.Increment(ref _eventCount);
+            int addressCount = Counts.AddOrUpdate(address, 1, (_, count) => count + 1);
+            ulong relativeAddress = BaseAddress != 0 && address >= BaseAddress ? address - BaseAddress : address;
+            string line = string.Join(
+                ',',
+                DateTimeOffset.UtcNow.ToString("O", CultureInfo.InvariantCulture),
+                eventCount.ToString(CultureInfo.InvariantCulture),
+                $"0x{address:x}",
+                $"0x{relativeAddress:x}",
+                addressCount.ToString(CultureInfo.InvariantCulture),
+                $"0x{x0:x}",
+                $"0x{x1:x}",
+                $"0x{x2:x}",
+                $"0x{x3:x}",
+                $"0x{x4:x}",
+                $"0x{x5:x}",
+                $"0x{x6:x}",
+                $"0x{x7:x}",
+                $"0x{x8:x}",
+                $"0x{x9:x}",
+                $"0x{x10:x}",
+                $"0x{x11:x}",
+                $"0x{x12:x}",
+                $"0x{x13:x}",
+                $"0x{x14:x}",
+                $"0x{x15:x}",
+                $"0x{x19:x}",
+                $"0x{x20:x}",
+                $"0x{x21:x}",
