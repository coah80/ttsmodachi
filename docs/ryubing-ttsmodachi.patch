+        private static void ApplyPcmAck(IMemoryManager memory, ulong address, ulong ttsObject, RequestProbe probe)
+        {
+            if (string.IsNullOrWhiteSpace(PcmAckFile))
+            {
+                return;
+            }
+
+            try
+            {
+                if (!File.Exists(PcmAckFile))
+                {
+                    return;
+                }
+
+                string token = File.ReadAllText(PcmAckFile).Trim();
+                if (string.IsNullOrWhiteSpace(token) || string.Equals(token, _lastPcmAckToken, StringComparison.Ordinal))
+                {
+                    return;
+                }
+
+                _lastPcmAckToken = token;
+                if (_pcmDumpRemainingBytes <= 0)
+                {
+                    return;
+                }
+
+                _pcmDumpRemainingBytes = 0;
+                Trace(memory, address, "pcm", "host-ack", ttsObject, 0, probe);
+            }
+            catch
+            {
+            }
+        }
