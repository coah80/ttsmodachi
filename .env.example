DISCORD_TOKEN=
SYNC_COMMANDS_ON_START=true

RENDERER_URL=http://tts-worker:8080
RENDERER_CLIENT_TIMEOUT_SECONDS=120
RENDERER_HOST_PORT=18080
DATABASE_PATH=/data/ttsmodachi.sqlite3

TTSMODACHI_WORKER_ROMS=US
TTSMODACHI_US_WORKERS=1
TTSMODACHI_RENDER_TIMEOUT=20
TTSMODACHI_RENDER_READY_TIMEOUT_SECONDS=2
TTSMODACHI_POLL_INTERVAL=0.01
TTSMODACHI_IDLE_SUSPEND_SECONDS=10
TTSMODACHI_IDLE_RESUME_TIMEOUT_MS=1000
TTSMODACHI_MAX_INFLIGHT_RENDERS=32
TTSMODACHI_CACHE_MAX_BYTES=1073741824
TTSMODACHI_ENGINE_VERSION=ttsmodachi-v1
TTSMODACHI_PANEL_TOKEN=
TTSMODACHI_PUBLIC_HOSTS=tomo.coah80.com
TTSMODACHI_PANEL_URL=https://tomo.coah80.com
TTSMODACHI_PANEL_SIGNING_KEY=

# Put patched ROMs in ./roms with these names:
# US.cxi
# EU.cxi
# JP.cxi
# KR.cxi

# Experimental Tomodachi Life: Living the Dream renderer.
# Use TTSMODACHI_WORKER_ROMS=LTD, or include LTD in the comma-separated list,
# after building the patched Ryubing checkout and pointing at your local NSP.
TTSMODACHI_LTD_ENABLED=false
TTSMODACHI_LTD_WARM=true
TTSMODACHI_LTD_GAME_PATH=
TTSMODACHI_LTD_RYUBING_PATH=ryubing-work/ryubing
TTSMODACHI_LTD_DATA_DIR=ltd-work/ryubing-data
# Optional private Ryubing root-data-dir seed. If DATA_DIR is empty or missing
# save/profile data, the worker copies this seed before booting LTD.
TTSMODACHI_LTD_SEED_DATA_DIR=
TTSMODACHI_LTD_WORK_DIR=ltd-work/ltd-renderer
TTSMODACHI_LTD_TIMEOUT_SECONDS=150
TTSMODACHI_LTD_PREWARM=true
TTSMODACHI_LTD_PREWARM_PRIMER=true
TTSMODACHI_LTD_IDLE_SUSPEND_SECONDS=10
TTSMODACHI_LTD_IDLE_RESUME_TIMEOUT_MS=1000
TTSMODACHI_LTD_NO_PRESENT=false
TTSMODACHI_LTD_NO_PRESENT_AFTER_PREWARM=false
TTSMODACHI_LTD_DISCARD_PRESENT=true
TTSMODACHI_LTD_DISCARD_PRESENT_AFTER_PREWARM=false
TTSMODACHI_LTD_DISABLE_SHADER_CACHE=true
TTSMODACHI_LTD_QUIET_LOGS=true
TTSMODACHI_LTD_WINDOW_WIDTH=320
TTSMODACHI_LTD_WINDOW_HEIGHT=180
TTSMODACHI_LTD_LOW_DPI_WINDOW=true
TTSMODACHI_LTD_GRAPHICS_BACKEND=
TTSMODACHI_LTD_RESOLUTION_SCALE=
TTSMODACHI_LTD_BACKEND_THREADING=
TTSMODACHI_LTD_BOOT_INPUT=false
TTSMODACHI_LTD_APPLIANCE=true
TTSMODACHI_LTD_APPLIANCE_PARK=true
TTSMODACHI_LTD_APPLIANCE_PARK_POLL_MS=25
TTSMODACHI_LTD_APPLIANCE_PARK_MAX_MS=0
TTSMODACHI_LTD_APPLIANCE_HOST_PARK_SLEEP_MS=8
TTSMODACHI_LTD_APPLIANCE_DISPATCH_ON_CAPTURE=true
TTSMODACHI_LTD_APPLIANCE_CONTEXT_RESTORE=true
TTSMODACHI_LTD_APPLIANCE_PARK_ON_CAPTURE_READY=false
TTSMODACHI_LTD_APPLIANCE_REQUEST_CONTEXT_CAPTURE=false
TTSMODACHI_LTD_APPLIANCE_REQUEST_CONTEXT_REPLAY=false
TTSMODACHI_LTD_APPLIANCE_DISPATCH_CONTEXT_REPLAY=false
TTSMODACHI_LTD_APPLIANCE_TRACE_REQUEST_REGISTERS=false
TTSMODACHI_LTD_APPLIANCE_CONTEXT_TRACE_ADDRS=
TTSMODACHI_LTD_APPLIANCE_CONTEXT_TRACE_ONCE=true
TTSMODACHI_LTD_APPLIANCE_CONTEXT_DUMP_DIR=
TTSMODACHI_LTD_APPLIANCE_CONTEXT_DUMP_BYTES=0
TTSMODACHI_LTD_APPLIANCE_CONTEXT_DUMP_REGISTERS=0,1,2,3,19,20,21,22,23,24,29,30,31
TTSMODACHI_LTD_MEMORY_WRITE_TRACE=
TTSMODACHI_LTD_MEMORY_WRITE_RANGES=
TTSMODACHI_LTD_MEMORY_WRITE_MAX_EVENTS=20000
TTSMODACHI_LTD_MEMORY_WRITE_START_SECONDS=
TTSMODACHI_LTD_MEMORY_WRITE_DURATION_SECONDS=
TTSMODACHI_LTD_APPLIANCE_TRAMPOLINE_RETURN_ADDR=0x3004
TTSMODACHI_LTD_APPLIANCE_CONTEXT_RESUME_ADDR=0
TTSMODACHI_LTD_APPLIANCE_TRACE_CONSUMER_REGISTERS=false
TTSMODACHI_LTD_APPLIANCE_CONSUMER_DUMP_DIR=
TTSMODACHI_LTD_APPLIANCE_CONSUMER_DUMP_BYTES=0
TTSMODACHI_LTD_APPLIANCE_CONSUMER_DUMP_REGISTERS=0,19,21,22
TTSMODACHI_LTD_APPLIANCE_CONSUMER_FRAME_FILE=
TTSMODACHI_LTD_APPLIANCE_CONSUMER_FRAME_LOAD=true
TTSMODACHI_LTD_APPLIANCE_CONSUMER_FRAME_SAVE=true
TTSMODACHI_LTD_APPLIANCE_MEMORY_PATCH_FILE=
TTSMODACHI_LTD_APPLIANCE_MEMORY_PATCH_ONCE=true
TTSMODACHI_LTD_APPLIANCE_REQUEST_DUMP_DIR=
TTSMODACHI_LTD_APPLIANCE_REQUEST_DUMP_BYTES=0
TTSMODACHI_LTD_APPLIANCE_REQUEST_DUMP_ONCE=true
# Base NSP build-id 56BF85BD... address table. Override only for RE/debug.
TTSMODACHI_LTD_APPLIANCE_REQUEST_ADDR=0x4445cc
TTSMODACHI_LTD_APPLIANCE_CAPTURE_ADDRS=0x600f04,0x600efc
TTSMODACHI_LTD_APPLIANCE_PCM_DUMP_ADDRS=0x465714
TTSMODACHI_LTD_APPLIANCE_CONSUMER_CAPTURE_ADDRS=0x465598
TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_ADDR=0x465598
TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_MAX=8
TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_INTERVAL_MS=20
# Experimental faster parent consumer replay. It can return some short queued
# requests under 200ms, but it is not the stable default because burst tests can
# poison Ryubing's audio thread.
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_CAPTURE_ADDRS=0x2ad98c
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_ADDR=0x2ad98c
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_MAX=64
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_INTERVAL_MS=0
# Experimental higher-level consumer replay:
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_CAPTURE_ADDRS=0x465380
# TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_ADDR=0x465380
TTSMODACHI_LTD_APPLIANCE_CONSUMER_KICK_AFTER_DISPATCH_MAX=0
TTSMODACHI_LTD_APPLIANCE_MANAGER_GLOBAL_ADDR=0x32ccde0
TTSMODACHI_LTD_APPLIANCE_MANAGER_INNER_OFFSET=0xda0
TTSMODACHI_LTD_APPLIANCE_REQUEST_OBJECT_OFFSET=0x1860
TTSMODACHI_LTD_APPLIANCE_TEXT_BUFFER_OFFSET=0xcc
TTSMODACHI_LTD_APPLIANCE_TEXT_POINTER_OFFSET=0xc0
TTSMODACHI_LTD_APPLIANCE_TEXT_LENGTH_OFFSET=0xc8
TTSMODACHI_LTD_APPLIANCE_READY_FLAG_OFFSET=0x8d8
TTSMODACHI_LTD_APPLIANCE_ALT_TEXT_FLAG_OFFSET=0x8d0
TTSMODACHI_LTD_APPLIANCE_VOICE_CONTEXT_OFFSET=0x8e8
TTSMODACHI_LTD_APPLIANCE_PCM_TEXT_BYTES_PER_SECOND=14.0
TTSMODACHI_LTD_APPLIANCE_PCM_CAPTURE_TEXT_BYTES_PER_SECOND=14.0
TTSMODACHI_LTD_PCM_WAIT_FOR_QUIET_TAIL=false
TTSMODACHI_LTD_PCM_END_SILENCE_SECONDS=0.45
TTSMODACHI_LTD_PCM_END_SILENCE_THRESHOLD=128
TTSMODACHI_LTD_PCM_END_PAD_SECONDS=0.04
TTSMODACHI_LTD_ENABLE_DSP_TRACE=false
TTSMODACHI_LTD_DUMMY_AUDIO=true
TTSMODACHI_LTD_MUTE_DEVICE_SINK=true
