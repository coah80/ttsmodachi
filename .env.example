DISCORD_TOKEN=
SYNC_COMMANDS_ON_START=true

RENDERER_URL=http://tts-worker:8080
RENDERER_HOST_PORT=18080
DATABASE_PATH=/data/ttsmodachi.sqlite3

TTSMODACHI_WORKER_ROMS=US
TTSMODACHI_US_WORKERS=1
TTSMODACHI_RENDER_TIMEOUT=20
TTSMODACHI_RENDER_READY_TIMEOUT_SECONDS=2
TTSMODACHI_POLL_INTERVAL=0.01
TTSMODACHI_IDLE_SUSPEND_SECONDS=10
TTSMODACHI_IDLE_RESUME_TIMEOUT_MS=1000
TTSMODACHI_MAX_INFLIGHT_RENDERS=32
TTSMODACHI_CACHE_MAX_BYTES=1073741824
TTSMODACHI_ENGINE_VERSION=ttsmodachi-v1
TTSMODACHI_PANEL_TOKEN=
TTSMODACHI_PUBLIC_HOSTS=tomo.coah80.com
TTSMODACHI_PANEL_URL=https://tomo.coah80.com
TTSMODACHI_PANEL_SIGNING_KEY=

# Put patched ROMs in ./roms with these names:
# US.cxi
# EU.cxi
# JP.cxi
# KR.cxi
